<Window x:Class="ShopSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ShopSystem.Views"
        Title="🛒 Shop Management System" Height="760" Width="1200"
        MinHeight="640" MinWidth="900"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top header bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text=" ShopSystem" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Chalongchai Phothong"
                           Foreground="#93C5FD" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tab content -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Margin="12">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding"     Value="16,8"/>
                    <Setter Property="FontSize"    Value="13"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="Foreground"  Value="{StaticResource MutedBrush}"/>
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="📊  Dashboard">
                <views:DashboardView/>
            </TabItem>
            <TabItem Header="📦  Products  (DB 1)">
                <views:ProductView/>
            </TabItem>
            <TabItem Header="👥  Customers  (DB 2)">
                <views:CustomerView/>
            </TabItem>
            <TabItem Header="🛍️  Orders  (DB 3)">
                <views:OrderView/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
