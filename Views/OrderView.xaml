<UserControl x:Class="ShopSystem.Views.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ShopSystem.ViewModels"
             xmlns:local="clr-namespace:ShopSystem.Helpers">
    <UserControl.DataContext>
        <vm:OrderViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- Left: orders list + detail -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Order Management" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Database: orders.db  (links to products.db + customers.db)" FontSize="12"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>

            <!-- Orders grid -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,10">
                <DataGrid Style="{StaticResource ModernGrid}"
                          ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"        Binding="{Binding Id}"          Width="45"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Date"     Binding="{Binding OrderDate, StringFormat=yyyy-MM-dd}" Width="95"/>
                        <DataGridTextColumn Header="Total (฿)" Binding="{Binding TotalAmount, StringFormat=N0}" Width="90"/>
                        <DataGridTextColumn Header="Status"   Binding="{Binding Status}"      Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Status update bar -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Update Status:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="💾 Update" Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateStatusCommand}" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="🗑 Delete Order" Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteOrderCommand}"/>
                </Grid>
            </Border>

            <!-- Order items detail -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernGrid}"
                          ItemsSource="{Binding SelectedOrder.Items}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product"   Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Qty"       Binding="{Binding Quantity}"    Width="50"/>
                        <DataGridTextColumn Header="Unit (฿)"  Binding="{Binding UnitPrice, StringFormat=N0}" Width="90"/>
                        <DataGridTextColumn Header="Sub (฿)"   Binding="{Binding Subtotal, StringFormat=N0}"  Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Right: create order panel -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Create New Order" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

                <TextBlock Text="Select Customer" Style="{StaticResource FormLabel}"/>
                <ComboBox ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="Name" Margin="0,0,0,8"/>

                <TextBlock Text="Select Product" Style="{StaticResource FormLabel}"/>
                <ComboBox ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          DisplayMemberPath="Name" Margin="0,0,0,4"/>

                <!-- Product price hint -->
                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8">
                    <Run Text="Price: "/>
                    <Run Text="{Binding SelectedProduct.Price, StringFormat=N0}"/>
                    <Run Text=" ฿  Stock: "/>
                    <Run Text="{Binding SelectedProduct.Stock}"/>
                </TextBlock>

                <TextBlock Text="Quantity" Style="{StaticResource FormLabel}"/>
                <TextBox Style="{StaticResource ModernTextBox}" Margin="0,0,0,8"
                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="➕  Add to Cart" Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddToCartCommand}" Margin="0,0,0,12"/>

                <!-- Cart -->
                <TextBlock Text="Cart" FontWeight="Bold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>

                <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                        CornerRadius="6" Height="180">
                    <DataGrid Style="{StaticResource ModernGrid}" BorderThickness="0"
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Qty"     Binding="{Binding Quantity}"    Width="40"/>
                            <DataGridTextColumn Header="Sub ฿"   Binding="{Binding Subtotal, StringFormat=N0}" Width="70"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove Item"
                                          Command="{Binding DataContext.RemoveFromCartCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Border>

                <!-- Total -->
                <Border Background="#EFF6FF" CornerRadius="6" Padding="10,6" Margin="0,8,0,12">
                    <Grid>
                        <TextBlock Text="Total:" FontWeight="Bold"/>
                        <TextBlock HorizontalAlignment="Right" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}">
                            <Run Text="{Binding CartTotal, StringFormat=N0}"/>
                            <Run Text=" ฿"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <Button Content="✅  Place Order" Style="{StaticResource SuccessButton}"
                        Command="{Binding PlaceOrderCommand}" Margin="0,0,0,6"/>
                <Button Content="✕  Clear Cart" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearCartCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
